{
  "name": "klarpath-crm-app",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "prisma migrate deploy && next start -p 3000",
    "start:dev": "prisma db push --schema=./schema.prisma && next start -p 3000",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push --schema=./schema.prisma",
    "prisma:generate": "prisma generate --schema=./schema.prisma",
    "worker": "tsx worker.ts",
    "postinstall": "prisma generate --schema=./schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.9.1",
    "jsonwebtoken": "^9.0.0",
    "next": "^16.0.0",
    "nodemailer": "^6.9.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "redis": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "19.2.15",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.0",
    "babel-plugin-react-compiler": "latest",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0"
  }
}
